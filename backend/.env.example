# ---- Backend configuration ----
# Copy to `.env` and adjust. NEVER commit the real `.env`.

# Port the API listens on
PORT=4000

# Postgres connection string used by the API and seed script
DATABASE_URL=postgres://atri:atri@localhost:5432/atri

# Postgres connection string used ONLY by the integration test suite.
# Leave blank to skip DB integration tests (unit tests still run).
TEST_DATABASE_URL=postgres://atri:atri@localhost:5432/atri_test

# Absolute or relative path to the built Angular app. When present, the API
# serves the dashboard as static files from the same origin (no CORS needed).
# In Docker this points at the copied dist folder.
STATIC_DIR=

# ---- Default health thresholds ----
# These seed the `thresholds` table on first boot. After that they are editable
# at runtime via PUT /api/thresholds, so changing them needs no code change.
CPU_MAX_PCT=85
MEMORY_MAX_PCT=90
STORAGE_MAX_PCT=90
LATENCY_MAX_MS=250
OFFLINE_SECS=120
