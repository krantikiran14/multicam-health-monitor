# ---- Simulator configuration (change these, no code edit needed) ----
# Copy to `.env` and adjust.

# How many cameras to simulate (minimum 5, recommended 10)
CAMERA_COUNT=10

# How often each camera reports, in milliseconds (default 30s)
REPORT_INTERVAL_MS=30000

# Probability (0..1) that a camera raises a fault on a given tick
FAULT_PROBABILITY=0.02

# Base URL of the backend that receives readings
BACKEND_URL=http://localhost:4000
